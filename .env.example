# ─────────────────────────────────────────────────────────────
# PromptForge AI — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# Get a free PostgreSQL DB at: https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/promptforge?sslmode=require"

# ── Clerk Authentication ──────────────────────────────────────
# Create a free app at: https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret (Clerk dashboard → Webhooks → your endpoint)
CLERK_WEBHOOK_SECRET=whsec_xxxx

# ── Groq AI ──────────────────────────────────────────────────
# Get a free API key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxx

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe (Optional) ────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# STRIPE_PRO_PRICE_ID=price_xxxx
